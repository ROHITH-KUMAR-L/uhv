# ─── Supabase ────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_JWT_SECRET=

# ─── Google Gemini ────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ─── VirusTotal ───────────────────────────────────────────
VIRUSTOTAL_API_KEY=your-virustotal-api-key

# ─── SMS Gateway (Local Mobile Server) ───────────────────
# LAN IP example: http://192.168.1.10:5000/send
# Or ngrok URL:   https://xxxx.ngrok.io/send
SMS_GATEWAY_URL=http://192.168.x.x:PORT/send
SMS_GATEWAY_SECRET=optional-shared-secret

# ─── Email ────────────────────────────────────────────────
EMAIL_PROVIDER=smtp                     # 'smtp' or 'resend'
RESEND_API_KEY=your-resend-api-key      # Only if EMAIL_PROVIDER=resend
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@scamshield.app

# ─── App ──────────────────────────────────────────────────
APP_ENV=development
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000
FILE_MAX_SIZE_MB=60
TEMP_FILE_DIR=/tmp/scamshield
OTP_EXPIRY_MINUTES=5
EMAIL_CODE_EXPIRY_MINUTES=10
